# Google Maps Platform — enable Map Tiles API + Photorealistic 3D Tiles
# https://console.cloud.google.com/apis/library/tile.googleapis.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Meshy.ai text-to-3D — https://www.meshy.ai/api
MESHY_API_KEY=your_meshy_api_key

# Supabase — https://supabase.com/dashboard → Settings → API
# Project URL (required for Google/email auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (sb_publishable_...) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Optional: secret/service role for server RPC (sb_secret_... or service_role JWT)
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Public site URL (OAuth redirects + share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Force demo GLB instead of Meshy (default false when MESHY_API_KEY is set)
# NEXT_PUBLIC_DEMO_MODE=true
