# Google Maps Platform — enable Map Tiles API + Photorealistic 3D Tiles
# https://console.cloud.google.com/apis/library/tile.googleapis.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cesium ion (optional fallback / ion assets)
# NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token

# Meshy.ai text-to-3D — https://www.meshy.ai/api
MESHY_API_KEY=your_meshy_api_key

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role only on the server (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Public site URL (used for OAuth redirects and share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enable demo generation without Meshy (uses a sample GLB)
# NEXT_PUBLIC_DEMO_MODE=true
